LLM_PROVIDER=openai
LLM_BASE_URL=https://api.deepseek.com
DEFAULT_MODEL=deepseek-v4-flash
LLM_API_KEY=
API_AUTH_TOKEN=
API_ALLOW_REMOTE_WITHOUT_TOKEN=false
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIMENSIONS=384
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
EMBEDDING_QUERY_PREFIX=
EMBEDDING_PASSAGE_PREFIX=
EMBEDDING_TRUST_REMOTE_CODE=false
EMBEDDING_CACHE_PATH=./data/hf-cache
EMBEDDING_LOCAL_FILES_ONLY=true
EMBEDDING_FALLBACK_ENABLED=true
KNOWLEDGE_STORE_PROVIDER=sqlite
KNOWLEDGE_STORE_PATH=./data/knowledge_base_312_live.db
KNOWLEDGE_STORE_DATABASE_URL=
VECTOR_STORE_PROVIDER=qdrant_local
VECTOR_STORE_PATH=./data/qdrant-312-live
VECTOR_STORE_COLLECTION=multi_tool_agent_chunks_e5_small_live
VECTOR_STORE_QUERY_FALLBACK_ENABLED=false
MAX_TOOL_STEPS=3
RUN_STORAGE_PATH=./data/multi_tool_agent_312_live.db
DOCUMENT_UPLOAD_MAX_BYTES=20971520
DOCUMENT_UPLOAD_MAX_EXTRACTED_CHARS=2000000
DOCUMENT_PDF_MAX_PAGES=300
EXTRACTION_EXPORT_PATH=./data/exports

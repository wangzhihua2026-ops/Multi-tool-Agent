APP_NAME=Multi Tool Agent
ENVIRONMENT=local
LOG_LEVEL=INFO
API_PREFIX=/api
API_AUTH_TOKEN=
API_ALLOW_REMOTE_WITHOUT_TOKEN=false
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=30
DEFAULT_MODEL=gpt-4.1-mini
EMBEDDING_PROVIDER=hash
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIMENSIONS=128
EMBEDDING_API_KEY=
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
EMBEDDING_QUERY_PREFIX=
EMBEDDING_PASSAGE_PREFIX=
EMBEDDING_TRUST_REMOTE_CODE=false
EMBEDDING_CACHE_PATH=
EMBEDDING_LOCAL_FILES_ONLY=false
EMBEDDING_FALLBACK_ENABLED=true
KNOWLEDGE_STORE_PROVIDER=sqlite
KNOWLEDGE_STORE_PATH=./data/knowledge_base.db
KNOWLEDGE_STORE_DATABASE_URL=
VECTOR_STORE_PROVIDER=qdrant_local
VECTOR_STORE_URL=http://127.0.0.1:6333
VECTOR_STORE_COLLECTION=multi_tool_agent_chunks
VECTOR_STORE_PATH=./data/qdrant
VECTOR_STORE_TIMEOUT_SECONDS=15
VECTOR_STORE_API_KEY=
VECTOR_STORE_QUERY_FALLBACK_ENABLED=false
SESSION_HISTORY_LIMIT=12
MCP_CONFIG_PATH=./config/mcp_servers.json
MAX_TOOL_STEPS=3
MAX_TOOL_RETRIES=3
KNOWLEDGE_BASE_ENABLED=false
RUN_STORAGE_PATH=./data/multi_tool_agent.db
DOCUMENT_UPLOAD_MAX_BYTES=20971520
DOCUMENT_UPLOAD_MAX_EXTRACTED_CHARS=2000000
DOCUMENT_PDF_MAX_PAGES=300
EXTRACTION_EXPORT_PATH=./data/exports
LLM_API_KEY=
OPENAI_API_KEY=
